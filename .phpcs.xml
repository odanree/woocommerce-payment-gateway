<?xml version="1.0"?>
<ruleset name="WC-Gateway-HighRisk">
    <description>
        WordPress-Extra with modern PHP style conventions.
        This plugin targets PHP 8.1+ where PSR-12 style (4-space indent, short
        array syntax, closure-as-argument patterns) is standard.
        Security, naming, escaping, and i18n rules from WordPress-Extra are
        fully enforced.
    </description>

    <rule ref="WordPress-Extra">
        <!-- Indentation: allow 4-space indent instead of tabs -->
        <exclude name="Generic.WhiteSpace.DisallowSpaceIndent"/>

        <!-- Arrays: allow short syntax [] -->
        <!-- Note: WordPress-Extra pulls in Universal, not Generic, for this sniff -->
        <exclude name="Universal.Arrays.DisallowShortArraySyntax"/>
        <exclude name="Generic.Arrays.DisallowShortArraySyntax"/>

        <!-- Array formatting: don't require each associative key on its own line -->
        <exclude name="WordPress.Arrays.ArrayDeclarationSpacing"/>

        <!-- Assignment alignment: don't require = alignment across statements -->
        <exclude name="Generic.Formatting.MultipleStatementAlignment"/>

        <!-- Function calls: allow closure-as-argument on same line as call -->
        <exclude name="PEAR.Functions.FunctionCallSignature"/>

        <!-- Array arrow alignment: don't require => alignment -->
        <exclude name="WordPress.Arrays.MultipleStatementAlignment"/>
    </rule>

    <!-- Enforce consistent 4-space indentation -->
    <rule ref="Generic.WhiteSpace.ScopeIndent">
        <properties>
            <property name="indent" value="4"/>
            <property name="tabIndent" value="false"/>
        </properties>
    </rule>

    <arg name="extensions" value="php"/>
    <arg name="colors"/>
    <arg value="sp"/>

    <file>includes/</file>
    <file>woocommerce-payment-gateway.php</file>

    <exclude-pattern>vendor/</exclude-pattern>
    <exclude-pattern>tests/</exclude-pattern>
    <exclude-pattern>node_modules/</exclude-pattern>
</ruleset>
